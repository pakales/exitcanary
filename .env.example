# Server-only. Never prefix with NEXT_PUBLIC_.
OPENAI_API_KEY=

# Emergency cost-control switch. Set false to force deterministic mapping.
EXITCANARY_LIVE_MAPPING_ENABLED=true

# Optional keyed salt for pseudonymous demo rate-limit identities.
EXITCANARY_QUOTA_SALT=

# Optional canonical deployment origin used by browser-origin validation.
EXITCANARY_PUBLIC_ORIGIN=http://localhost:3000
